# ═══════════════════════════════════════════════════════════════════════════════
# .env.docker.example — Docker Environment Template
#
# WHY THIS FILE EXISTS:
#   This is the template for .env.docker — the environment file used exclusively
#   by the Docker container (NOT by PM2).
#
# HOW TO USE:
#   1. Copy this file:  cp .env.docker.example .env.docker
#   2. Fill in your actual production values
#   3. Never commit .env.docker (it's in .gitignore)
#
# COEXISTENCE STRATEGY (Phase 1):
#   PM2 reads: .env          (PORT=5000, production traffic)
#   Docker reads: .env.docker (PORT=5001, test in parallel)
#   Nginx: untouched, continues proxying to PM2 on port 5000
#   Once Docker is verified, change PORT to 5000 here and stop PM2.
# ═══════════════════════════════════════════════════════════════════════════════


# ── Server Port ───────────────────────────────────────────────────────────────
# PHASE 1: Use 5001 so Docker runs alongside PM2 (which uses 5000).
# PHASE 2 cutover: Change to 5000, then stop PM2.
#
# With network_mode: host, this port binds directly on the EC2 host.
# Test Docker: curl http://localhost:5001/health
# Test PM2:    curl http://localhost:5000/health
PORT=5001


# ── Database ──────────────────────────────────────────────────────────────────
# With network_mode: host, 'localhost' inside the container = EC2 host's localhost.
# MySQL is on 127.0.0.1 — reachable as localhost from the container.
# NO CHANGE NEEDED to this URL compared to your existing .env.
#
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://your_db_user:your_db_password@localhost:3306/your_database"


# ── CORS Allowed Origins ──────────────────────────────────────────────────────
# Comma-separated list of frontend origins that can make requests to the API.
# credentials:true requires explicit origins — do NOT use wildcard *.
CORS_ORIGIN="https://pierush.xyz,https://www.pierush.xyz,https://admin.pierush.xyz"


# ── Environment ───────────────────────────────────────────────────────────────
# Must be 'production' for:
#   1. Express to disable verbose error messages
#   2. Our logger.ts to use stdout-only logging (no file transports)
NODE_ENV="production"


# ── Logging ───────────────────────────────────────────────────────────────────
# In production, use 'info'. Use 'debug' only when actively debugging.
# All logs go to stdout/stderr → visible via: docker logs pierush-backend
LOG_LEVEL="info"


# ── JWT Authentication ────────────────────────────────────────────────────────
# Use the exact same secrets as your existing .env — tokens must be compatible
# between PM2 and Docker instances (both serve the same users).
JWT_SECRET="your_jwt_secret_here_must_match_existing_env"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here_must_match_existing_env"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"


# ── Razorpay Payment Gateway ─────────────────────────────────────────────────
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"


# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"
