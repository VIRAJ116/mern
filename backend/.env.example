# .env file
PORT=3000
# Use the new format: mysql://user:password@host:port/database
DATABASE_URL=""

# CORS Configuration — comma-separated list of allowed origins
# credentials:true requires explicit origins, wildcard * is not allowed
CORS_ORIGIN=""

# Environment
NODE_ENV="development"

# Logging
LOG_LEVEL="debug"  # Options: error, warn, info, debug

JWT_SECRET=""
JWT_EXPIRES_IN="1h"

# razorpay credentials
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""